# UTEAM Server Environment Variables
# Railway will auto-import these variables

# MongoDB connection string (REQUIRED)
MONGODB_URI=mongodb+srv://ItzYakudza:itzyakudza@uteam.hv0lo4x.mongodb.net/uteam?retryWrites=true&w=majority

# JWT Secret for authentication (REQUIRED)
JWT_SECRET=uteam_super_secret_jwt_key_2026_production

# Server port (Railway sets this automatically)
PORT=3001

# Update system secret key
UPDATE_SECRET=uteam_production_secret_2026_xyz

# JWT token expiration
JWT_EXPIRES_IN=7d

# URL клиентского приложения (для CORS)
CLIENT_URL=http://localhost:3000

# URL портала разработчиков
DEVELOPER_PORTAL_URL=http://localhost:3002

# Путь для загрузки файлов
UPLOAD_PATH=./uploads

# Максимальный размер файла (в байтах, 500MB)
MAX_FILE_SIZE=524288000

# Режим работы (development/production)
NODE_ENV=production

# Список администраторов платформы (через запятую)
# Пользователи с этими никнеймами будут автоматически получать роль admin при входе
# Пример: ADMIN_USERS=ItzYakudza,Admin,Moderator
ADMIN_USERS=ItzYakudza,Admin
