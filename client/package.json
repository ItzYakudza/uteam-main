{
  "name": "uteam-client",
  "version": "1.0.0",
  "description": "UTEAM - Game Platform Client",
  "author": "UTEAM <support@uteam.com>",
"main": "build/electron.js",
  "scripts": {
"react-build": "cross-env GENERATE_SOURCEMAP=false react-scripts build",
"build": "npm run react-build && electron-builder build --win --dir -p never"
  },
"build": {
  "appId": "com.uteam.app",
  "productName": "UTEAM",
  "files": [
    "build/**/*",
    "node_modules/**/*",
    "package.json",
    {
      "from": "src/main/main.js",
      "to": "main.js"
    }
  ],
  "directories": {
    "output": "dist"
  }
},
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.6.2",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "react-scripts": "5.0.1",
    "socket.io-client": "^4.6.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "rimraf": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      "last 1 electron version"
    ],
    "development": [
      "last 1 electron version"
    ]
  },
  "homepage": "./"
}
